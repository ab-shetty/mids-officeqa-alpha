{
  "__comment_1": "Template for submissions/<uuid>.json in your fork of RDI-Foundation/officeqa-agentbeats-leaderboard.",
  "__comment_2": "Fill <YOUR_GHCR_USER>, <COMMIT_SHA>, and agentbeats_ids.purple.  Rename file to submissions/<NEW_UUID>.json and put it on a branch named quick-submit-<NEW_UUID>.",
  "__comment_3": "The <COMMIT_SHA> must be a commit in your purple-agent-officeqa repo that has amber-manifest.json5 at the root.",

  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_openai_api_key": { "type": "string", "secret": true }
    },
    "required": ["officeqa_agent_openai_api_key"],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
          "num_questions": 246,
          "difficulty": "all",
          "tolerance": 0,
          "run_id": 1
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/<YOUR_GHCR_USER>/purple-agent-officeqa/<COMMIT_SHA>/amber-manifest.json5",
      "config": {
        "openai_api_key":   "${config.officeqa_agent_openai_api_key}",
        "openai_model":     "gpt-5.4-mini",
        "reasoning_effort": "medium"
      }
    }
  },
  "bindings": [
    { "to": "#gateway.green",            "from": "#green.a2a" },
    { "to": "#gateway.purple1",          "from": "#officeqa_agent.a2a" },
    { "to": "#green.proxy",              "from": "#gateway.proxy", "weak": true },
    { "to": "#officeqa_agent.proxy",     "from": "#gateway.proxy", "weak": true }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green":          "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "<YOUR_AGENTBEATS_ID_FROM_agentbeats.dev>"
    }
  }
}
